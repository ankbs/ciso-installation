# ==============================================================================
# TEMPLATE: CISO Automation & Managed Service - Environment Variables
# Copy this file to '.env' and fill in your local secrets.
# WARNING: Never commit the '.env' file containing active credentials!
# ==============================================================================

# --- CISO Assistant Configuration ---
# The URL of your CISO Assistant VPS instance
CISO_API_URL=https://ciso.deinedomain.de
# Personal Access Token (PAT) for API authorization
CISO_API_TOKEN=TokenYourApiTokenHere

# --- Microsoft Graph API Configuration (Local Dev / App Registration) ---
# Your M365 Tenant ID
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
# The App Registration (Client) ID
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# The Client Secret (Only for local development!)
AZURE_CLIENT_SECRET=YourSuperSecretClientSecretHere

# --- Database Credentials (Used by Docker-Compose on the VPS) ---
POSTGRES_DB=ciso_db
POSTGRES_USER=ciso_admin
POSTGRES_PASSWORD=ChooseAStrongPasswordForDatabaseHere
